{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:18789/claude-events",
            "timeout": 10,
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer $OPENCLAW_GATEWAY_TOKEN",
              "X-Event-Type": "work-completed"
            },
            "allowedEnvVars": ["OPENCLAW_GATEWAY_TOKEN"]
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt|permission_prompt",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:18789/claude-events",
            "timeout": 10,
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer $OPENCLAW_GATEWAY_TOKEN",
              "X-Event-Type": "user-input-required"
            },
            "allowedEnvVars": ["OPENCLAW_GATEWAY_TOKEN"]
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:18789/claude-events",
            "timeout": 10,
            "headers": {
              "Content-Type": "application/json",
              "Authorization": "Bearer $OPENCLAW_GATEWAY_TOKEN",
              "X-Event-Type": "error-occurred"
            },
            "allowedEnvVars": ["OPENCLAW_GATEWAY_TOKEN"]
          }
        ]
      }
    ]
  }
}
