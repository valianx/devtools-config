            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/Users/mario/.claude/hooks/notify-openclaw-progress.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/Users/mario/.claude/hooks/notify-openclaw-progress.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUseFailure": [
